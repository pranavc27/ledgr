# Google Gemini API key for the LLM categorization pass (Pass 2).
# Get one at https://aistudio.google.com/apikey
# The app still runs without it — the long tail just stays uncategorized.
GEMINI_API_KEY=your_key_here

# Optional model override. Default is gemini-2.5-flash-lite (reliable on the
# free tier). Some keys have no free quota for gemini-2.0-flash. If you hit
# 429s, try: gemini-2.5-flash-lite or gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash-lite
